<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QSightClient.Pages.StatusPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20">

        <StackPanel Spacing="12">

            <TextBlock
                Text="Q-Sight Agent Status"
                FontSize="24"
                FontWeight="Bold"/>
            
            <Border Padding="12" BorderThickness="1" CornerRadius="6">
                <StackPanel Spacing="8">

                    <TextBlock Text="Agent Status"/>
                    <TextBlock x:ConnectionId='2' x:Name="AgentStatusText" Text="Running"/>

                    <TextBlock Text="Current File"/>
                    <TextBlock x:ConnectionId='3' x:Name="CurrentFileText" Text="-"/>

                    <TextBlock Text="Queue Size"/>
                    <TextBlock x:ConnectionId='4' x:Name="QueueSizeText" Text="0"/>

                    <TextBlock Text="Last Message"/>
                    <TextBlock x:ConnectionId='5' x:Name="LastMessageText" Text="-"/>

                    <ProgressBar x:ConnectionId='6'
                        x:Name="ScanProgressBar"
                        Minimum="0"
                        Maximum="100"
                        Height="20"
                        Width ="300"
                        HorizontalAlignment="Left"/>

                    <Button x:ConnectionId='7'
                        Content="Cancel Scan"
                                                
                        Width="120"/>

                    <ListView x:ConnectionId='8'
                        x:Name="QueueList"
                        Height="120"/>


                </StackPanel>
            </Border>

        </StackPanel>

    </Grid>

</Page>

