<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QSightClient.Pages.StatusPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="16">

            <TextBlock Text="System Status"
                       FontSize="28"
                       FontWeight="SemiBold"/>
 
            <Border
                Background ="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="10"
                Padding="16">

                <StackPanel Spacing="8">

                    <TextBlock Text="Agent Status"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="Last IPC Message:"/>

                    <TextBlock x:ConnectionId='2'
                        x:Name="MessageText"
                        Text="Waiting..."
                        FontFamily="Consolas"/>

                </StackPanel>

            </Border>

        </StackPanel>
    </ScrollViewer>

</Page>

