<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QSightClient.Pages.StatusPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="16">

            <TextBlock Text="System Status"
                       FontSize="28"
                       FontWeight="SemiBold"/>
 
            <Border
                Background ="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="10"
                Padding="16">

                <StackPanel Spacing="12" Padding="20">

                    <TextBlock
                    Text="Agent Status"
                    FontSize="24"
                    FontWeight="Bold"/>

                    <TextBlock
                    x:Name="LastMessageText"
                    Text="Waiting..."
                    FontSize="14"/>

                </StackPanel>

            </Border>

        </StackPanel>
    </ScrollViewer>

</Page>